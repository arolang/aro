# Stub server gives deterministic responses for the canvas demo.
occurrence-check: true
pre-script: if ! python3 -c 'import socket,sys; s=socket.socket(); s.settimeout(0.1); sys.exit(0 if s.connect_ex(("127.0.0.1",18791))==0 else 1)' 2>/dev/null; then (python3 Examples/UptimeMonitor/stub.py 18791 >/dev/null 2>&1 </dev/null &); for i in $(seq 1 100); do python3 -c 'import socket,sys; s=socket.socket(); s.settimeout(0.1); sys.exit(0 if s.connect_ex(("127.0.0.1",18791))==0 else 1)' 2>/dev/null && exit 0; sleep 0.1; done; echo "stub failed to start" >&2; exit 1; fi

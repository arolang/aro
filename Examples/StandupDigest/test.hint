# StandupDigest fixtures live in stub.py. Same launch pattern as HTTPClient.
occurrence-check: true
pre-script: if ! python3 -c 'import socket,sys; s=socket.socket(); s.settimeout(0.1); sys.exit(0 if s.connect_ex(("127.0.0.1",18781))==0 else 1)' 2>/dev/null; then (python3 Examples/StandupDigest/stub.py 18781 >/dev/null 2>&1 </dev/null &); for i in $(seq 1 100); do python3 -c 'import socket,sys; s=socket.socket(); s.settimeout(0.1); sys.exit(0 if s.connect_ex(("127.0.0.1",18781))==0 else 1)' 2>/dev/null && exit 0; sleep 0.1; done; echo "stub failed to start" >&2; exit 1; fi

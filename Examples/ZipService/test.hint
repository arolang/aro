# Test hints for ZipService
# Package plugin compilation requires Swift compiler at runtime
# Zip library requires zlib.h which is not available on Windows CI
timeout: 300
# Wipe any archive from a previous run so the test really verifies that THIS
# run created it (not a stale artifact left in the source tree).
pre-script: rm -f Examples/ZipService/content/archive.zip
# After aro finishes, verify the archive was actually created, is a real zip,
# and contains both source files. Use python3 -m zipfile (stdlib, present on
# every modern Linux distro and on macOS — unzip isn't always installed on
# minimal CI runners). `-t` runs an integrity / CRC check; `-l` lists the
# contents we then grep.
test-script: test -s Examples/ZipService/content/archive.zip && python3 -m zipfile -t Examples/ZipService/content/archive.zip && python3 -m zipfile -l Examples/ZipService/content/archive.zip | grep -q 'file1.txt' && python3 -m zipfile -l Examples/ZipService/content/archive.zip | grep -q 'file2.txt'

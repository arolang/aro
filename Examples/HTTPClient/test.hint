# Test hints for HTTPClient
# Uses occurrence-check since API responses contain dynamic data (weather, timestamps)
# Verifies HTTP client functionality and response structure
occurrence-check: true
# Start a local stub for the Open-Meteo API so the test does not depend on
# a third-party service that occasionally returns 502s. The stub
# self-terminates after 60s; pkill cleans up any leftover from a previous run.
pre-script: pkill -f 'Examples/HTTPClient/stub.py' 2>/dev/null; (python3 Examples/HTTPClient/stub.py 18765 >/dev/null 2>&1 </dev/null &); for i in $(seq 1 100); do python3 -c 'import socket,sys; s=socket.socket(); s.settimeout(0.1); sys.exit(0 if s.connect_ex(("127.0.0.1",18765))==0 else 1)' 2>/dev/null && exit 0; sleep 0.1; done; echo "stub failed to start" >&2; exit 1

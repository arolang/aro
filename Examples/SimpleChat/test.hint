# Test hints for SimpleChat
mode: both
# HTTP endpoint test order may vary
occurrence-check: true
# Socket servers hang on Windows CI
skip-on-windows: Socket tests not supported on Windows CI
# The native (compiled) socket+HTTP server returns 599 on Linux CI: the server
# starts but requests into the compiled feature set fail only under Linux
# compiled (interpreter mode passes on Linux; both modes pass on macOS). Tracked
# for a native-server root fix; skip only the compiled-on-Linux combination.
skip-compiled-on-linux: native socket+HTTP server returns 599 on Linux CI (tracked)

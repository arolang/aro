# Test hints for URLClient
# The jsonplaceholder/httpbin endpoints are stubbed locally (see stub.py) —
# both live services flake from cloud runners (httpbin regularly answers
# 503 HTML), which used to break this example in CI and locally. With the
# stub, both interpreter and compiled mode run hermetically.
pre-script: if ! python3 -c 'import socket,sys; s=socket.socket(); s.settimeout(0.1); sys.exit(0 if s.connect_ex(("127.0.0.1",18767))==0 else 1)' 2>/dev/null; then (python3 Examples/URLClient/stub.py 18767 >/dev/null 2>&1 </dev/null &); for i in $(seq 1 100); do python3 -c 'import socket,sys; s=socket.socket(); s.settimeout(0.1); sys.exit(0 if s.connect_ex(("127.0.0.1",18767))==0 else 1)' 2>/dev/null && exit 0; sleep 0.1; done; echo "stub failed to start" >&2; exit 1; fi
